# ==========================================
# AUTOPAY BACKEND ENVIRONMENT VARIABLES
# ==========================================

# Server
PORT=5000
NODE_ENV=development

# ==========================================
# OPTIMAPAY API
# ==========================================
OPTIMA_API_KEY=YOUR_OPTIMA_API_KEY
OPTIMA_API_SECRET=YOUR_OPTIMA_API_SECRET

# ==========================================
# FIREBASE ADMIN
# ==========================================
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-client-email

# Replace \n with actual newlines when adding in Render
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n
